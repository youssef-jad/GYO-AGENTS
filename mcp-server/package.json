{
  "name": "gyo-agents-mcp",
  "version": "1.0.0",
  "description": "MCP server that exposes GYO-AGENTS prompts as callable tools for any AI coding agent",
  "type": "module",
  "bin": {
    "gyo-agents-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "cursor",
    "claude",
    "cline",
    "kiro",
    "gemini"
  ],
  "license": "MIT"
}